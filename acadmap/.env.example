# Supabase (optional for local JSON-only development)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL for OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# One-time Google OAuth setup (local script only — not needed at runtime)
# SUPABASE_ACCESS_TOKEN=sbp_...
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
# LINKEDIN_OAUTH_CLIENT_ID=...
# LINKEDIN_OAUTH_CLIENT_SECRET=...

# Planner feature flags
ENABLE_PLANNER_COLLAB=false
USE_OFFICIAL_UCSB_CONNECTOR=false

# UCSB Developer API (optional — enables live course catalog fetch)
# Register at https://developer.ucsb.edu and enable Academics - Curriculums
UCSB_API_KEY=
UCSB_CURRICULUM_CACHE_HOURS=24

# Upstash Redis — per-IP rate limits on /api/roadmaps* (optional locally)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — production error tracking (optional locally)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Transcript PDF import — AI fallback for scanned/low-text PDFs (optional locally)
AI_GATEWAY_API_KEY=
TRANSCRIPT_AI_MODEL=google/gemini-2.0-flash
TRANSCRIPT_MAX_FILE_MB=5
TRANSCRIPT_AI_FALLBACK_MIN_COURSES=3
